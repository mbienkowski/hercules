{
  "version": 1,
  "hooks": {
    "beforeShellExecution": [
      { "command": "python3 ${CURSOR_PLUGIN_ROOT}/hooks/hercules_gate.py shell" }
    ],
    "beforeMCPExecution": [
      { "command": "python3 ${CURSOR_PLUGIN_ROOT}/hooks/hercules_gate.py mcp" }
    ],
    "afterFileEdit": [
      { "command": "python3 ${CURSOR_PLUGIN_ROOT}/hooks/hercules_gate.py after_edit" }
    ]
  }
}
